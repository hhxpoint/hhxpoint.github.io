---
title: 3D粒子交互
date: 2026-03-28 00:00:00
type: particle
comments: false
---
<div id="test-container" style="width: 100vw; height: 100vh; background: #000; position: fixed; top: 0; left: 0; z-index: 9999;">
  <div id="debug-info" style="position: fixed; top: 20px; left: 20px; color: white; font-family: monospace; z-index: 10000; background: rgba(0,0,0,0.8); padding: 15px; border-radius: 10px;">
    <h3>3D粒子系统调试信息</h3>
    <div id="status">正在初始化...</div>
    <div id="three-status">Three.js: 未加载</div>
    <div id="container-status">容器: 未找到</div>
    <div id="error-info" style="color: #ff6b6b; margin-top: 10px;"></div>
  </div>
</div>

<script>
// 简单的测试脚本
document.addEventListener('DOMContentLoaded', function() {
  const statusDiv = document.getElementById('status');
  const threeStatusDiv = document.getElementById('three-status');
  const containerStatusDiv = document.getElementById('container-status');
  const errorInfoDiv = document.getElementById('error-info');
  
  // 检查容器
  const container = document.getElementById('test-container');
  if(container) {
    containerStatusDiv.textContent = '容器: 已找到 ✓';
    containerStatusDiv.style.color = '#44ff44';
  } else {
    containerStatusDiv.textContent = '容器: 未找到 ✗';
    containerStatusDiv.style.color = '#ff4444';
    errorInfoDiv.textContent = '错误: 找不到容器元素';
    return;
  }
  
  // 检查Three.js
  if(typeof THREE !== 'undefined') {
    threeStatusDiv.textContent = 'Three.js: 已加载 ✓';
    threeStatusDiv.style.color = '#44ff44';
    statusDiv.textContent = '初始化粒子系统...';
    
    // 创建简单的粒子
    try {
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
      const renderer = new THREE.WebGLRenderer();
      renderer.setSize(window.innerWidth, window.innerHeight);
      container.appendChild(renderer.domElement);
      
      // 创建粒子
      const geometry = new THREE.BufferGeometry();
      const particleCount = 10000;
      const positions = new Float32Array(particleCount * 3);
      const colors = new Float32Array(particleCount * 3);
      
      for(let i = 0; i < particleCount; i++) {
        const i3 = i * 3;
        positions[i3] = (Math.random() - 0.5) * 100;
        positions[i3 + 1] = (Math.random() - 0.5) * 100;
        positions[i3 + 2] = (Math.random() - 0.5) * 100;
        
        colors[i3] = 1.0;
        colors[i3 + 1] = 0.8 + Math.random() * 0.2;
        colors[i3 + 2] = 0.2;
      }
      
      geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
      geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));
      
      const material = new THREE.PointsMaterial({
        size: 1,
        vertexColors: true,
        transparent: true,
        opacity: 0.8
      });
      
      const particles = new THREE.Points(geometry, material);
      scene.add(particles);
      
      camera.position.z = 50;
      
      // 动画循环
      function animate() {
        requestAnimationFrame(animate);
        particles.rotation.x += 0.001;
        particles.rotation.y += 0.002;
        renderer.render(scene, camera);
      }
      
      animate();
      statusDiv.textContent = '粒子系统运行中 ✓';
      statusDiv.style.color = '#44ff44';
      
    } catch(error) {
      errorInfoDiv.textContent = '错误: ' + error.message;
      console.error('粒子系统错误:', error);
    }
    
  } else {
    threeStatusDiv.textContent = 'Three.js: 未加载 ✗';
    threeStatusDiv.style.color = '#ff4444';
    statusDiv.textContent = '等待Three.js加载...';
    
    // 尝试加载Three.js
    const script = document.createElement('script');
    script.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
    script.onload = function() {
      threeStatusDiv.textContent = 'Three.js: 已加载 ✓';
      threeStatusDiv.style.color = '#44ff44';
      statusDiv.textContent = 'Three.js加载成功，请刷新页面';
    };
    script.onerror = function() {
      threeStatusDiv.textContent = 'Three.js: 加载失败 ✗';
      threeStatusDiv.style.color = '#ff4444';
      errorInfoDiv.textContent = '无法加载Three.js，请检查网络连接';
    };
    document.head.appendChild(script);
  }
});
</script>